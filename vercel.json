{
  "rewrites": [
    { "source": "/paid-media", "destination": "/paid-media.html" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/paid-media",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/paid-media.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/pacientes-modelo",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/pacientes-modelo/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/social",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/social/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, max-age=0, must-revalidate" }
      ]
    }
  ]
}
